# Supabase — copy to .env.local and fill in from
# https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Either name works — the app accepts both:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Server-only — enables in-app user management (invites, role changes).
# Supabase → Project Settings → API keys → secret/service_role. Never expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only — enables notification emails (deliverables, invoices, invites).
# https://resend.com → API Keys. Optional; the app skips emails when unset.
RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM="Lithos Solutions <info@lithossolutions.com>"
